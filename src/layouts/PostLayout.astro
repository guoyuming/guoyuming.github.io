---
import { getCollection } from 'astro:content';

const { frontmatter, slug } = Astro.props;

// Helper to convert slug to title
function slugToTitle(slug: string): string {
  return slug
    .replace(/^\d{6}-/, '') // Remove date prefix like "170130-"
    .replace(/-/g, ' ')     // Replace hyphens with spaces
    .trim();
}

// Get all posts to find prev/next (sorted alphabetically by title)
const allPosts = await getCollection('posts');
const sortedPosts = allPosts
  .map(post => ({
    ...post,
    displayTitle: post.data.title || slugToTitle(post.slug)
  }))
  .sort((a, b) => a.displayTitle.localeCompare(b.displayTitle, 'zh-CN'));

const currentIndex = sortedPosts.findIndex(post => post.slug === slug);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

// Default theme for all posts
const theme = {
  bg: '#faf8f5',
  text: '#2d2011',
  accent: '#8b4513',
  muted: '#6b6b6b'
};

// SEO
const description = frontmatter.description || "Yuming's Blog - 产品、技术与思考";
const canonicalURL = new URL(`/posts/${slug}`, Astro.site);
const pageTitle = `${frontmatter.title} | Yuming`;

// JSON-LD structured data
const jsonLD = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": frontmatter.title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": "Yuming",
    "url": "https://guoyuming.github.io"
  },
  "publisher": {
    "@type": "Person",
    "name": "Yuming"
  },
  "datePublished": frontmatter.date?.toISOString(),
  "dateModified": frontmatter.date?.toISOString(),
  "url": canonicalURL.href,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.href
  }
};
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/android-chrome-512x512.png" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="Yuming's Blog RSS" href="/rss.xml" />
    <title>{pageTitle}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="Yuming's Blog" />
    {frontmatter.date && <meta property="article:published_time" content={frontmatter.date.toISOString()} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />

    <!-- FOUC prevention: apply saved theme before first paint -->
    <script is:inline>
    (function(){
      var t = localStorage.getItem('theme');
      if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
    })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
    <style define:vars={{
      themeBg: theme.bg,
      themeText: theme.text,
      themeAccent: theme.accent,
      themeMuted: theme.muted
    }}>
      /* ============================================================
         ThomasMoes Bold - Article Theme (Light Cream)
         Inspired by §2.9 Article Body Typography
         ============================================================ */
      :root {
        --theme-bg: var(--themeBg);
        --theme-text: var(--themeText);
        --theme-accent: var(--themeAccent);
        --theme-muted: var(--themeMuted);

        /* Theme-dependent UI colors */
        --nav-backdrop: rgba(250, 248, 245, 0.85);
        --nav-border: rgba(45, 32, 17, 0.1);
        --nav-btn-bg: rgba(45, 32, 17, 0.08);
        --nav-btn-hover: rgba(45, 32, 17, 0.15);
        --nav-divider-bg: rgba(45, 32, 17, 0.15);
        --code-bg: rgba(45, 32, 17, 0.06);
        --code-border: rgba(45, 32, 17, 0.08);
        --divider-color: rgba(45, 32, 17, 0.15);
        --post-nav-bg: rgba(45, 32, 17, 0.04);
        --post-nav-border: rgba(45, 32, 17, 0.08);
        --post-nav-hover-bg: rgba(45, 32, 17, 0.08);
        --footer-border: rgba(45, 32, 17, 0.1);
        --social-hover-bg: rgba(139, 69, 19, 0.08);
        --btn-bg: rgba(45, 32, 17, 0.08);
        --btn-hover: rgba(45, 32, 17, 0.15);

        /* Typography */
        --font-display: 'Playfair Display', Georgia, serif;
        --font-heading: 'Instrument Sans', -apple-system, sans-serif;
        --font-body: 'Noto Serif SC', Georgia, serif;
        --font-mono: 'SF Mono', 'Monaco', 'Inconsolata', monospace;

        /* Layout */
        --max-width: 1440px;
        --content-width: 660px;
        --nav-height: 80px;
        --radius-nav: 30px;
        --radius-pill: 100px;
        --radius-sm: 8px;
        --radius-card: 20px;
      }

      /* Dark Mode Override */
      [data-theme="dark"] {
        --theme-bg: #0d0c16;
        --theme-text: #ebe5de;
        --theme-accent: #e4432e;
        --theme-muted: rgba(235, 229, 222, 0.5);
        --nav-backdrop: rgba(13, 12, 22, 0.85);
        --nav-border: rgba(235, 229, 222, 0.15);
        --nav-btn-bg: rgba(255, 255, 255, 0.06);
        --nav-btn-hover: rgba(255, 255, 255, 0.15);
        --nav-divider-bg: rgba(235, 229, 222, 0.15);
        --code-bg: rgba(235, 229, 222, 0.08);
        --code-border: rgba(235, 229, 222, 0.1);
        --divider-color: rgba(235, 229, 222, 0.15);
        --post-nav-bg: rgba(235, 229, 222, 0.04);
        --post-nav-border: rgba(235, 229, 222, 0.08);
        --post-nav-hover-bg: rgba(235, 229, 222, 0.08);
        --footer-border: rgba(235, 229, 222, 0.15);
        --social-hover-bg: rgba(228, 67, 46, 0.1);
        --btn-bg: rgba(255, 255, 255, 0.15);
        --btn-hover: rgba(255, 255, 255, 0.35);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
      }

      body {
        font-family: var(--font-body);
        background: var(--theme-bg);
        color: var(--theme-text);
        line-height: 1.8;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* Links - ThomasMoes §1.3 border-bottom style */
      a {
        color: var(--theme-accent);
        text-decoration: none;
        border-bottom: 1px solid currentColor;
        transition: all 0.2s ease;
      }

      a:hover {
        border-bottom-color: transparent;
      }

      /* ============================================================
         Sticky Article Navigation - ThomasMoes §2.5
         ============================================================ */
      .article-nav {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--nav-backdrop);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--nav-border);
      }

      .article-nav-container {
        max-width: var(--max-width);
        height: var(--nav-height);
        margin: 0 auto;
        padding: 0 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top-left-radius: var(--radius-nav);
        border-top-right-radius: var(--radius-nav);
      }

      .article-nav-logo {
        display: flex;
        align-items: center;
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        color: var(--theme-text);
        border-bottom: none;
        transition: transform 0.2s ease;
      }

      .article-nav-logo:hover {
        transform: scale(1.1);
        border-bottom: none;
      }

      .article-nav-title {
        flex: 1;
        text-align: center;
        margin: 0 40px;
      }

      .article-nav-subtitle {
        font-family: var(--font-heading);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.5;
        margin-bottom: 2px;
      }

      .article-nav-title-text {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.6;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 400px;
        margin: 0 auto;
      }

      .article-nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* Nav Buttons - ThomasMoes §1.11 glass style */
      .nav-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 20px;
        font-family: var(--font-heading);
        font-size: 0.8125rem;
        font-weight: 500;
        border-radius: var(--radius-pill);
        border: none;
        border-bottom: none;
        background: var(--nav-btn-bg);
        color: var(--theme-text);
        transition: all 0.2s ease;
        height: 36px;
      }

      .nav-btn:hover {
        background: var(--nav-btn-hover);
        transform: scale(1.05);
        border-bottom: none;
      }

      /* Nav divider - ThomasMoes §2.5 */
      .nav-divider {
        width: 1px;
        height: 24px;
        background: var(--nav-divider-bg);
        margin: 0 4px;
      }

      /* ============================================================
         Article Container
         ============================================================ */
      .article-container {
        flex: 1;
        width: 100%;
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 80px 24px 100px;
      }

      /* ============================================================
         Article Header - ThomasMoes Type 01 inspired (§2.9)
         Large centered title, dramatic presentation
         ============================================================ */
      .article-header {
        text-align: center;
        margin-bottom: 60px;
        padding-bottom: 40px;
      }

      .article-title {
        font-family: var(--font-display);
        font-size: 3.5rem;
        font-weight: 400;
        line-height: 1.15;
        margin-bottom: 28px;
        letter-spacing: -0.01em;
      }

      .article-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        font-family: var(--font-heading);
        font-size: 0.875rem;
        color: var(--theme-muted);
        letter-spacing: 0.02em;
      }

      .article-meta-dot {
        width: 4px;
        height: 4px;
        background: var(--theme-muted);
        border-radius: 50%;
        opacity: 0.5;
      }

      /* Article Divider */
      .article-divider {
        height: 1px;
        background: var(--divider-color);
        margin: 0 auto 48px;
        max-width: 80px;
      }

      /* ============================================================
         Article Body - ThomasMoes §2.9 Type 01 reading style
         ============================================================ */
      .article-body {
        font-size: 1.25rem;
        line-height: 1.9;
      }

      .article-body h1,
      .article-body h2,
      .article-body h3,
      .article-body h4,
      .article-body h5,
      .article-body h6 {
        font-family: var(--font-display);
        font-weight: 400;
        margin-top: 3.5rem;
        margin-bottom: 1.25rem;
      }

      .article-body h2 {
        font-size: 2rem;
        line-height: 1.3;
      }

      .article-body h3 {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.35;
      }

      .article-body p {
        margin-bottom: 1.75em;
      }

      /* Inline links - ThomasMoes §1.3 border-bottom */
      .article-body a {
        color: var(--theme-accent);
        border-bottom: 1px solid currentColor;
      }

      .article-body a:hover {
        border-bottom-color: transparent;
      }

      /* Blockquote - elevated style */
      .article-body blockquote {
        border-left: 3px solid var(--theme-accent);
        padding: 1.5rem 0 1.5rem 2rem;
        margin: 3rem 0;
        font-family: var(--font-display);
        font-style: italic;
        font-size: 1.375rem;
        line-height: 1.7;
        opacity: 0.85;
      }

      .article-body blockquote p:last-child {
        margin-bottom: 0;
      }

      .article-body ul,
      .article-body ol {
        margin-left: 1.5rem;
        margin-bottom: 1.75em;
      }

      .article-body li {
        margin-bottom: 0.75em;
      }

      .article-body code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        background: var(--code-bg);
        padding: 0.2em 0.5em;
        border-radius: var(--radius-sm);
        border: 1px solid var(--code-border);
      }

      .article-body pre {
        background: #1a1825;
        color: #ebe5de;
        padding: 1.5rem 2rem;
        border-radius: var(--radius-card);
        overflow-x: auto;
        margin: 2.5rem -1rem;
      }

      .article-body pre code {
        background: none;
        padding: 0;
        color: inherit;
        border: none;
      }

      .article-body img {
        display: block;
        max-width: 100%;
        max-height: 600px;
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 12px;
        margin: 3rem auto;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }

      .article-body figcaption {
        text-align: center;
        font-family: var(--font-heading);
        font-size: 0.875rem;
        color: var(--theme-muted);
        opacity: 0.7;
        margin-top: -1.5rem;
        margin-bottom: 2rem;
      }

      .article-body hr {
        border: none;
        height: 1px;
        background: var(--divider-color);
        margin: 3.5rem 0;
      }

      .article-body strong {
        font-weight: 700;
        color: var(--theme-text);
      }

      /* ============================================================
         Post Navigation - Card style with hover
         ============================================================ */
      .post-nav {
        display: flex;
        justify-content: space-between;
        margin-top: 80px;
        padding-top: 48px;
        border-top: 1px solid var(--divider-color);
        gap: 24px;
      }

      .post-nav-item {
        flex: 1;
        max-width: 45%;
      }

      .post-nav-item a {
        display: block;
        padding: 24px;
        background: var(--post-nav-bg);
        border-radius: var(--radius-card);
        border: 1px solid var(--post-nav-border);
        border-bottom: 1px solid var(--post-nav-border);
        color: var(--theme-text);
        transition: all 0.2s ease;
      }

      .post-nav-item a:hover {
        background: var(--post-nav-hover-bg);
        transform: scale(1.02);
        border-color: var(--theme-accent);
        border-bottom-color: var(--theme-accent);
      }

      .post-nav-label {
        font-family: var(--font-heading);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        opacity: 0.5;
        margin-bottom: 10px;
      }

      .post-nav-title {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.4;
      }

      .post-nav-item.next {
        text-align: right;
        margin-left: auto;
      }

      /* ============================================================
         Footer
         ============================================================ */
      .article-footer {
        text-align: center;
        padding: 48px 24px;
        border-top: 1px solid var(--footer-border);
        color: var(--theme-muted);
        font-size: 0.875rem;
      }

      .article-footer p {
        margin: 0;
        font-family: var(--font-heading);
      }

      .social-links {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        margin-bottom: 16px;
      }

      .social-links a,
      .social-link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--theme-muted);
        transition: all 0.2s ease;
        background: none;
        border: none;
        border-bottom: none;
        padding: 8px;
        cursor: pointer;
        border-radius: 50%;
      }

      .social-links a:hover,
      .social-link-btn:hover {
        color: var(--theme-accent);
        background: var(--social-hover-bg);
        transform: scale(1.1);
        border-bottom: none;
      }

      .social-links svg {
        width: 20px;
        height: 20px;
        fill: currentColor;
      }

      .wechat-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
      }

      .wechat-modal-content {
        background: #fff;
        border-radius: var(--radius-card);
        padding: 32px;
        text-align: center;
        position: relative;
        max-width: 320px;
        width: 90%;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.3);
      }

      .wechat-modal-content img {
        width: 200px;
        height: 200px;
        object-fit: contain;
        border-radius: var(--radius-sm);
      }

      .wechat-modal-content p {
        color: #333;
        margin: 12px 0 0;
        font-size: 0.95rem;
      }

      .wechat-modal-close {
        position: absolute;
        top: 8px;
        right: 12px;
        background: none;
        border: none;
        font-size: 1.5rem;
        color: #999;
        cursor: pointer;
        line-height: 1;
      }

      .wechat-modal-close:hover {
        color: #333;
      }

      /* ============================================================
         Theme Toggle Button
         ============================================================ */
      .footer-row {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        margin-bottom: 16px;
      }

      .theme-toggle {
        position: absolute;
        right: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        background: var(--btn-bg);
        color: var(--theme-muted);
        border: 1px solid var(--nav-border);
        border-radius: var(--radius-pill);
        padding: 0 14px;
        height: 36px;
        font-family: var(--font-heading);
        font-size: 0.8125rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .theme-toggle:hover {
        background: var(--btn-hover);
        color: var(--theme-text);
        transform: scale(1.05);
      }

      .theme-toggle svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }

      .theme-toggle .icon-sun { display: inline; }
      .theme-toggle .icon-moon { display: none; }
      [data-theme="dark"] .theme-toggle .icon-sun { display: none; }
      [data-theme="dark"] .theme-toggle .icon-moon { display: inline; }

      /* ============================================================
         Responsive
         ============================================================ */
      @media (max-width: 768px) {
        .article-nav-container {
          padding: 0 24px;
          height: 64px;
        }

        .article-nav-logo {
          font-size: 1.25rem;
        }

        .article-nav-title {
          display: none;
        }

        .article-container {
          padding: 48px 20px 60px;
        }

        .article-title {
          font-size: 2.25rem;
        }

        .article-body {
          font-size: 1.125rem;
        }

        .article-body h2 {
          font-size: 1.625rem;
        }

        .article-body h3 {
          font-size: 1.25rem;
        }

        .article-body blockquote {
          font-size: 1.125rem;
          padding-left: 1.25rem;
        }

        .article-body pre {
          margin-left: -20px;
          margin-right: -20px;
          border-radius: 0;
          padding: 1.25rem 20px;
        }

        .post-nav {
          flex-direction: column;
          margin-top: 60px;
        }

        .post-nav-item {
          max-width: 100%;
        }

        .post-nav-item.next {
          text-align: left;
        }
      }

      @media (max-width: 480px) {
        .article-title {
          font-size: 1.875rem;
        }

        .nav-btn {
          padding: 6px 14px;
          font-size: 0.75rem;
        }
      }
    </style>
  </head>
  <body>
    <!-- Sticky Article Navigation - ThomasMoes §2.5 -->
    <nav class="article-nav">
      <div class="article-nav-container">
        <a href="/" class="article-nav-logo">Yuming</a>
        <div class="article-nav-title">
          <div class="article-nav-subtitle">Obsession</div>
          <div class="article-nav-title-text">{frontmatter.title}</div>
        </div>
        <div class="article-nav-actions">
          <a href="/" class="nav-btn">Home</a>
          <a href="/projects" class="nav-btn">Project</a>
          <a href="/archives" class="nav-btn">Writing</a>
        </div>
      </div>
    </nav>

    <main class="article-container">
      <article>
        <header class="article-header">
          <h1 class="article-title">{frontmatter.title}</h1>
          {frontmatter.date && (
            <div class="article-meta">
              <span>{frontmatter.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span class="article-meta-dot"></span>
              <span>Yuming</span>
            </div>
          )}
        </header>

        <div class="article-divider"></div>

        <div class="article-body">
          <slot />
        </div>

        <nav class="post-nav">
          {prevPost ? (
            <div class="post-nav-item prev">
              <a href={`/posts/${prevPost.slug}`}>
                <div class="post-nav-label">&larr; 上一篇</div>
                <div class="post-nav-title">{prevPost.displayTitle}</div>
              </a>
            </div>
          ) : <div class="post-nav-item"></div>}
          {nextPost ? (
            <div class="post-nav-item next">
              <a href={`/posts/${nextPost.slug}`}>
                <div class="post-nav-label">下一篇 &rarr;</div>
                <div class="post-nav-title">{nextPost.displayTitle}</div>
              </a>
            </div>
          ) : <div class="post-nav-item"></div>}
        </nav>
      </article>
    </main>

    <footer class="article-footer">
      <div class="footer-row">

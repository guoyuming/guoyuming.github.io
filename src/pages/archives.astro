---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Helper to convert slug to title
function slugToTitle(slug: string): string {
  return slug
    .replace(/^\d{6}-/, '') // Remove date prefix like "170130-"
    .replace(/-/g, ' ')     // Replace hyphens with spaces
    .trim();
}

const posts = await getCollection('posts');

// WeChat article mapping: slug → { url, title }
const wechatMap: Record<string, { url: string; title: string }> = {
  '为什么泡沫是好的': { url: 'https://mp.weixin.qq.com/s/5Q_LdJWBcYBdPsLI10-E8w', title: '为什么 AI 泡沫是好的？' },
  'manus-启示录': { url: 'https://mp.weixin.qq.com/s/caZy8yYruyFMQNCWtw9dYw', title: 'Manus 产品启示录' },
  '什么是真正-ai-native-产品设计': { url: 'https://mp.weixin.qq.com/s/SImvkVqsrGdYEGHXDLSQ1g', title: '什么是 AI Native 产品设计' },
  '深度研究几十个海外建站-saas-的精选案例让你掌握如何做-onboarding': { url: 'https://mp.weixin.qq.com/s/88OxLVpuLiAYiv3pxT1EQQ', title: '深度研究几十个海外 SaaS 总结出的 Onboarding 关键要素' },
  'vibe-coding-和个人专有-app': { url: 'https://mp.weixin.qq.com/s/9vDkgFL-i7qB-3XfLAPp4Q', title: 'Vibe coding 和个人专有 App' },
  'lovart-增长观察2025-年内有效': { url: 'https://mp.weixin.qq.com/s/w8l9vaCXFDwAB-9HxCRYmA', title: 'Lovart 增长做对了什么' },
  'vibe-coding-用户场景和-pmf': { url: 'https://mp.weixin.qq.com/s/_YhQLRVB2oAvmikhuBrG-A', title: '谁在用 Vibe coding？' },
  'lovable-vibe-coding-和自我表达': { url: 'https://mp.weixin.qq.com/s/8pUD46AYaTOK7rkfreN30Q', title: 'Lovable, Vibe Coding 和自我表达' },
  'replit-从-ide-到-coding-agent-的-10-年-接力': { url: 'https://mp.weixin.qq.com/s/wlgm4mk9k6KEPTHCjju98A', title: 'Replit：从 IDE 到 Coding Agent 的 10 年 接力' },
  '微信小程序和操作系统': { url: 'https://mp.weixin.qq.com/s/QDZjiULcYWEJI8ESXenS1g', title: '微信小程序和操作系统' },
  '我是如何用-ai-提高生产力的': { url: 'https://mp.weixin.qq.com/s/TAEaR361VH_R70UqR3c8eg', title: '如何提升工作的含 AI 量' },
  '人为什么需要品牌': { url: 'https://mp.weixin.qq.com/s/jvQGEtxJOZV3lgFZH57Jow', title: '用户为什么需要品牌？' },
  'dify-的产品思考': { url: 'https://mp.weixin.qq.com/s/pnb1XnZ2eeAuF8AlUUdeng', title: '用 Dify 可以做什么' },
  '为-ai-模型做产品': { url: 'https://mp.weixin.qq.com/s/iYzz5LXVvUpwr6zZgyHAeg', title: '为 AI 模型做产品' },
  'saas-产品的价值是什么': { url: 'https://mp.weixin.qq.com/s/YsOxRJxDKwIDxEuvhh_-gA', title: 'SaaS 产品的价值是什么？' },
  '如何做产品规划': { url: 'https://mp.weixin.qq.com/s/vnms_9SpphXbd0MY1K5x2Q', title: '如何做产品规划' },
  '如何晋升答辩评委视角建议收藏备用': { url: 'https://mp.weixin.qq.com/s/jfgbgEY2xX3vVCGR_2hLcA', title: '如何晋升答辩？评委视角建议（收藏备用）' },
  'gtd-及其应用': { url: 'https://mp.weixin.qq.com/s/9Q7Iih9_RqUHo3WvzMP5Kg', title: 'GTD（搞定一切） 及其应用' },
  '什么是运营': { url: 'https://mp.weixin.qq.com/s/3Edu2_xLe8Ah21lEU4iY7A', title: '什么是运营？' },
  'chatgpt-应用场景分析消费者评价': { url: 'https://mp.weixin.qq.com/s/S5wag25aNYPZu6Ph2c0bjw', title: 'ChatGPT 应用场景：分析消费者评价' },
  'chatgtp-通用性如何改造软件行业': { url: 'https://mp.weixin.qq.com/s/3WMatBIB3B7-YlunqHMQrg', title: 'ChatGTP 通用性如何改造软件行业' },
  'chatgpt-与知识工作者的窘境': { url: 'https://mp.weixin.qq.com/s/xWF3VVVFvVfbJgB4ZrCEfQ', title: 'ChatGPT 与知识工作者的窘境' },
  '创业者的差异化竞争': { url: 'https://mp.weixin.qq.com/s/Mrr3UPtoCstKP2C7bUmvSA', title: '创业者的差异化竞争' },
  'ai-生成新闻摘要-各公司-api-对比': { url: 'https://mp.weixin.qq.com/s/Q_ZDA0B40bMBwChWMH74-Q', title: 'AI 生成新闻摘要-各公司开放 API 对比' },
  '用-rice-框架评估优先级': { url: 'https://mp.weixin.qq.com/s/EwM-ccGY3ZHHu6iC2E1xnw', title: '用 RICE 框架评估优先级' },
  '210407-海外aso入门指南': { url: 'https://mp.weixin.qq.com/s/ID45L5MbXjStQElRVtFuPQ', title: '海外ASO入门指南' },
  '210317-ark-investsaas-将迎来下一个黄金十年': { url: 'https://mp.weixin.qq.com/s/GSw8JPoN_RiTT03e5n8vCg', title: 'ARK Invest：SaaS 将迎来下一个黄金十年？' },
};

const getPostUrl = (slug: string) => wechatMap[slug]?.url || `/posts/${slug}`;
const isExternal = (slug: string) => slug in wechatMap;

// Add derived titles and sort
const sortedPosts = posts
  .map(post => ({
    ...post,
    displayTitle: wechatMap[post.slug]?.title || post.data.title || slugToTitle(post.slug)
  }))
  .sort((a, b) => a.displayTitle.localeCompare(b.displayTitle, 'zh-CN'));

// Extract preview text from markdown body
const getExcerpt = (body: string, maxLength = 200) => {
  const plainText = body
    .replace(/^---[\s\S]*?---/, '') // Remove frontmatter
    .replace(/!\[.*?\]\(.*?\)/g, '') // Remove images
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // Convert links to text
    .replace(/[#*_`>\[\]]/g, '') // Remove markdown symbols
    .replace(/\n+/g, ' ') // Replace newlines with spaces
    .trim();
  
  if (plainText.length <= maxLength) return plainText;
  return plainText.substring(0, maxLength).trim() + '...';
};

---

<BaseLayout title="Writing">
  <div class="archive-split-container">
    <!-- Left Panel: Article List -->
    <aside class="article-list-panel">
      <div class="panel-header">
        <h1 class="page-title">Writing</h1>
        <p class="article-count">{posts.length} articles</p>
      </div>
      
      <nav class="article-list" role="listbox" aria-label="文章列表">
        {sortedPosts.map((post, index) => (
          <button
            class={`article-item ${index === 0 ? 'is-active' : ''}`}
            data-index={index}
            data-slug={post.slug}
            data-title={post.displayTitle}
            data-excerpt={getExcerpt(post.body)}
            data-url={getPostUrl(post.slug)}
            data-external={isExternal(post.slug) ? 'true' : 'false'}
            data-number={String(index + 1).padStart(2, '0')}
            role="option"
            aria-selected={index === 0 ? 'true' : 'false'}
          >
            <span class="article-item-number">{String(index + 1).padStart(2, '0')}</span>
            <span class="article-item-indicator"></span>
            <span class="article-item-title">{post.displayTitle}</span>
          </button>
        ))}
      </nav>
    </aside>

    <!-- Right Panel: Preview Card -->
    <section class="preview-panel">
      <a
        href={sortedPosts[0] ? getPostUrl(sortedPosts[0].slug) : '#'}
        class="preview-card"
        id="preview-card"
        {...(sortedPosts[0] && isExternal(sortedPosts[0].slug) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        <article class="preview-card-inner">
          <div class="preview-number" id="preview-number">01</div>
          <div class="preview-content">
            <h2 class="preview-title" id="preview-title">
              {sortedPosts[0]?.displayTitle}
            </h2>
            <p class="preview-excerpt" id="preview-excerpt">
              {getExcerpt(sortedPosts[0]?.body || '')}
            </p>
          </div>
          <div class="preview-cta">
            <span class="preview-cta-text">阅读文章</span>
            <span class="preview-cta-arrow">&rarr;</span>
          </div>
        </article>
      </a>
    </section>
  </div>

</BaseLayout>

<style>
  .archive-split-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    min-height: calc(100vh - var(--nav-height) - 200px);
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 20px;
  }

  /* Left Panel Styles */
  .article-list-panel {
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - var(--nav-height) - 120px);
    position: sticky;
    top: calc(var(--nav-height) + 60px);
  }

  .panel-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 0.25rem;
  }

  .article-count {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .article-list {
    flex: 1;
    overflow-y: auto;
    padding-right: 0.5rem;
    margin-right: -0.5rem;

    /* Hidden scrollbar - ThomasMoes §2.4 */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .article-list::-webkit-scrollbar {
    display: none;
  }

  /* Article Item Styles */
  .article-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.75rem 1rem;
    margin-bottom: 2px;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-align: left;
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    color: var(--color-text);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  /* Article Number - ThomasMoes §2.3 */
  .article-item-number {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 400;
    opacity: 0.3;
    min-width: 1.5rem;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .article-item-indicator {
    width: 3px;
    height: 0;
    background: var(--color-accent);
    border-radius: 2px;
    transition: height 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .article-item-title {
    flex: 1;
    line-height: 1.4;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .article-item:hover {
    background: var(--color-bg-alt);
  }

  .article-item:hover .article-item-number {
    opacity: 0.7;
    color: var(--color-accent);
  }

  .article-item:hover .article-item-indicator {
    height: 1.25rem;
  }

  .article-item:hover .article-item-title {
    transform: translateX(4px);
  }

  .article-item.is-active {
    background: var(--color-bg-alt);
    color: var(--color-accent);
  }

  .article-item.is-active .article-item-number {
    opacity: 1;
    color: var(--color-accent);
  }

  .article-item.is-active .article-item-indicator {
    height: 100%;
  }

  .article-item:focus {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-accent);
  }

  .article-item:focus:not(:focus-visible) {
    box-shadow: none;
  }

  /* Right Panel Styles */
  .preview-panel {
    display: flex;
    align-items: flex-start;
    padding-top: 3rem;
  }

  .preview-card {
    display: block;
    position: sticky;
    top: calc(var(--nav-height) + 60px);
    width: 100%;
    max-width: 500px;
    background: var(--color-bg-card, var(--color-bg-alt));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    animation: cardEnter 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .preview-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 6px rgba(13, 12, 22, 1), 0 0 0 8px rgba(228, 67, 46, 0.3);
    transform: scale(1.015);
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .preview-card-inner {
    padding: 2rem 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    min-height: 380px;
  }

  /* Large Preview Number - ThomasMoes §2.3 */
  .preview-number {
    font-family: var(--font-display);
    font-size: 5rem;
    font-weight: 400;
    line-height: 1;
    color: rgba(235, 229, 222, 0.06);
    margin-bottom: 8px;
    transition: color 0.3s ease;
  }

  .preview-card:hover .preview-number {
    color: rgba(228, 67, 46, 0.15);
  }

  .preview-content {
    flex: 1;
  }

  .preview-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 1rem;
    color: var(--color-text);
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.15s ease-out, transform 0.2s ease-out;
  }

  .preview-title.is-transitioning {
    opacity: 0;
    transform: translateY(-8px);
  }

  .preview-excerpt {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 0;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.15s ease-out 0.05s, transform 0.2s ease-out 0.05s;
  }

  .preview-excerpt.is-transitioning {
    opacity: 0;
    transform: translateY(-8px);
  }

  /* Preview CTA */
  .preview-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .preview-card:hover .preview-cta {
    color: var(--color-accent);
  }

  .preview-cta-arrow {
    transition: transform 0.2s ease;
  }

  .preview-card:hover .preview-cta-arrow {
    transform: translateX(4px);
  }

  /* Responsive Styles */
  @media (max-width: 900px) {
    .archive-split-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .article-list-panel {
      position: relative;
      top: 0;
      max-height: none;
    }

    .article-list {
      max-height: 50vh;
    }

    .preview-panel {
      padding-top: 0;
    }

    .preview-card {
      position: relative;
      top: 0;
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .page-title {
      font-size: 1.5rem;
    }

    .article-item {
      padding: 0.625rem 0.75rem;
      font-size: 0.875rem;
    }

    .article-item-number {
      font-size: 0.6875rem;
      min-width: 1.25rem;
    }

    .preview-card-inner {
      padding: 1.5rem;
      min-height: 300px;
    }

    .preview-number {
      font-size: 3.5rem;
    }

    .preview-title {
      font-size: 1.25rem;
    }

    .preview-content {
      min-height: 140px;
    }
  }
</style>

<script is:inline>
  (function() {
    // Get DOM elements
    var articleItems = document.querySelectorAll('.article-item');
    var previewTitle = document.getElementById('preview-title');
    var previewExcerpt = document.getElementById('preview-excerpt');
    var previewNumber = document.getElementById('preview-number');
    var previewCard = document.getElementById('preview-card');

    if (!previewTitle || !previewExcerpt || !previewCard || articleItems.length === 0) return;

    var currentItem = articleItems[0];

    // Update preview card with data from the clicked item
    function updatePreview(item) {
      var title = item.dataset.title;
      var excerpt = item.dataset.excerpt;
      var url = item.dataset.url;
      var number = item.dataset.number;
      var external = item.dataset.external === 'true';

      previewTitle.textContent = title;
      previewExcerpt.textContent = excerpt;
      if (previewNumber) previewNumber.textContent = number;
      previewCard.href = url;
      previewCard.target = external ? '_blank' : '';
      previewCard.rel = external ? 'noopener noreferrer' : '';
    }
    
    // Set active state on article item
    function setActiveItem(activeItem) {
      articleItems.forEach(function(item) {
        item.classList.remove('is-active');
        item.setAttribute('aria-selected', 'false');
      });
      activeItem.classList.add('is-active');
      activeItem.setAttribute('aria-selected', 'true');
      currentItem = activeItem;
    }
    
    // Attach click event listeners to each item
    articleItems.forEach(function(item) {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        setActiveItem(item);
        updatePreview(item);
      });
    });
    
    // Keyboard navigation
    var articleList = document.querySelector('.article-list');
    if (articleList) {
      articleList.addEventListener('keydown', function(e) {
        var currentIndex = Array.prototype.indexOf.call(articleItems, currentItem);
        var newIndex = currentIndex;
        
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          newIndex = Math.min(currentIndex + 1, articleItems.length - 1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          newIndex = Math.max(currentIndex - 1, 0);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (previewCard.target === '_blank') {
            window.open(previewCard.href, '_blank', 'noopener,noreferrer');
          } else {
            window.location.href = previewCard.href;
          }
          return;
        }
        
        if (newIndex !== currentIndex) {
          var newItem = articleItems[newIndex];
          setActiveItem(newItem);
          updatePreview(newItem);
          newItem.focus();
          newItem.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    }
  })();
</script>

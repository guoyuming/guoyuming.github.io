---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, url, urlLabel, tags, images } = project.data;

// Hero = first image, gallery = remaining images
const heroImage = images?.[0];
const galleryImages = images?.slice(1) || [];

// Next project logic
const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const currentIndex = sorted.findIndex(p => p.slug === project.slug);
const nextProject = sorted[(currentIndex + 1) % sorted.length];
---

<BaseLayout title={title}>
  <article class="project-detail">
    <!-- Section 1: Hero Image -->
    {heroImage && (
      <div class="project-hero">
        <img src={heroImage} alt={title} />
      </div>
    )}

    <!-- Section 2: Project Header -->
    <header class="project-header">
      <div class="project-title-row">
        <h1 class="project-title">{title}</h1>
        {url ? (
          <a href={url} target="_blank" rel="noopener noreferrer" class="project-cta">
            <span data-i18n="visit_project">{urlLabel || 'Visit project'}</span> <span class="cta-arrow">↗</span>
          </a>
        ) : urlLabel ? (
          <span class="project-badge">{urlLabel}</span>
        ) : null}
      </div>
    </header>

    <!-- Section 3: Description -->
    <div class="project-body">
      <Content />
    </div>

    <!-- Section 4: Media Gallery (remaining images) -->
    {galleryImages.length > 0 && (
      <div class={`project-gallery ${galleryImages.length === 1 ? 'single' : ''}`}>
        {galleryImages.map((img) => (
          <div class="gallery-item">
            <img src={img} alt={title} loading="lazy" />
          </div>
        ))}
      </div>
    )}

    <!-- Section 5: Tags -->
    {tags && tags.length > 0 && (
      <div class="project-tags">
        {tags.map((tag) => (
          <span class="tag-pill">{tag}</span>
        ))}
      </div>
    )}

    <!-- Section 6: Footer Navigation -->
    <footer class="project-footer">
      <a href="/projects" class="back-link" data-i18n="all_projects">&larr; All Projects</a>
      {nextProject && nextProject.slug !== project.slug && (
        <a href={`/projects/${nextProject.slug}`} class="next-link">
          <span data-i18n="next_project">Next: </span>{nextProject.data.title} &rarr;
        </a>
      )}
    </footer>
  </article>
</BaseLayout>

<style>
  .project-detail {
    max-width: 800px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Section 1: Hero Image */
  .project-hero {
    width: 100%;
    border-radius: var(--radius-card, 20px);
    overflow: hidden;
  }

  .project-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Section 2: Header */
  .project-header {
    display: flex;
    flex-direction: column;
  }

  .project-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .project-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text, #ebe5de);
    margin: 0;
    line-height: 1.2;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-pill, 100px);
    border: 1px solid var(--color-text-muted, rgba(235,229,222,0.6));
    color: var(--color-text, #ebe5de);
    text-decoration: none;
    transition: opacity 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-cta:hover {
    opacity: 0.85;
  }

  .cta-arrow {
    font-size: 16px;
  }

  .project-badge {
    display: inline-flex;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-pill, 100px);
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    color: var(--color-text-muted, rgba(235,229,222,0.6));
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Tags (bottom of page) */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: capitalize;
    color: var(--color-text-muted, rgba(235,229,222,0.6));
    background: rgba(235,229,222,0.08);
    border-radius: var(--radius-pill, 100px);
    padding: 4px 12px;
  }

  /* Section 3: Description */
  .project-body {
    max-width: 660px;
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text, #ebe5de);
  }

  .project-body :global(p) {
    margin: 0 0 1em;
  }

  .project-body :global(ul),
  .project-body :global(ol) {
    margin: 0 0 1em;
    padding-left: 0;
    list-style: none;
    border-left: 2px solid var(--color-accent, #e4432e);
    padding-left: 16px;
  }

  .project-body :global(li) {
    margin-bottom: 0.5em;
  }

  .project-body :global(a) {
    color: var(--color-accent, #e4432e);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Section 4: Gallery */
  .project-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .project-gallery.single {
    grid-template-columns: 1fr;
  }

  .gallery-item {
    border-radius: 12px;
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover {
    transform: scale(1.02);
  }

  .gallery-item img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  /* Section 5: Footer */
  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0;
    padding-top: 32px;
    border-top: 1px solid var(--color-border, rgba(255,255,255,0.08));
  }

  .back-link,
  .next-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted, rgba(235,229,222,0.6));
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover,
  .next-link:hover {
    color: var(--color-text, #ebe5de);
  }

  .next-link {
    text-align: right;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .project-detail {
      padding: 24px 16px 60px;
      gap: 32px;
    }

    .project-title {
      font-size: 1.75rem;
    }

    .project-title-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .project-gallery {
      grid-template-columns: 1fr;
    }

    .project-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .next-link {
      text-align: left;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const sortedProjects = projects.sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  if (a.data.order !== undefined) return -1;
  if (b.data.order !== undefined) return 1;
  return a.data.title.localeCompare(b.data.title, 'zh-CN');
});
---

<BaseLayout title="Project">
  <h2 class="section-heading" data-i18n="project">Project</h2>

  {sortedProjects.length === 0 ? (
    <p class="empty-state">Coming soon.</p>
  ) : (
    <ul class="project-grid">
      {sortedProjects.map((project) => {
        const coverImage = project.data.cover || `/images/projects/${project.slug}/cover.png`;
        return (
          <li class="browser-frame">
            <a href={`/projects/${project.slug}`} class="browser-frame-link">
              <div class="browser-content">
                <img
                  src={coverImage}
                  alt={project.data.title}
                  class="browser-preview"
                  loading="lazy"
                />
              </div>
              <div class="project-info">
                <span class="project-label">{project.data.title}</span>
                <svg class="project-arrow" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 10h12M12 6l4 4-4 4" />
                </svg>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</BaseLayout>

<style>
  .project-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 32px;
  }

  /* ---- Line Frame Card ---- */
  .browser-frame {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .browser-frame:hover {
    transform: scale(1.015);
    border-color: var(--color-border-hover);
    box-shadow: var(--card-shadow);
  }

  .browser-frame-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* ---- Content Area ---- */
  .browser-content {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .browser-preview {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---- Project Info ---- */
  .project-info {
    padding: 16px 20px;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .project-label {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .project-arrow {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--color-text-muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .browser-frame:hover .project-arrow {
    color: var(--color-text);
    transform: translateX(3px);
  }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .project-info {
      padding: 14px 16px;
    }
  }
</style>

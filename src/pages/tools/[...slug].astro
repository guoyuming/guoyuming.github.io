---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({
    params: { slug: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props;
const { Content } = await tool.render();
const { title, tagline, category, stage, url, logo, screenshots, color, verdicts } = tool.data;

// Next tool logic
const allTools = await getCollection('tools');
const sorted = allTools.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex(t => t.slug === tool.slug);
const nextTool = sorted[(currentIndex + 1) % sorted.length];
---

<BaseLayout title={title}>
  <article class="tool-detail" style={`--tool-color: ${color}`}>
    <!-- Section 1: Screenshot Hero -->
    {screenshots[0] && (
      <div class="tool-hero">
        <img src={screenshots[0]} alt={`${title} screenshot`} />
      </div>
    )}

    <!-- Section 2: Header -->
    <header class="tool-header">
      <div class="tool-header-left">
        <img src={logo} alt={title} class="tool-detail-logo" />
        <div class="tool-header-text">
          <h1 class="tool-title">{title}</h1>
          <span class="tool-category-pill">{category}</span>
        </div>
      </div>
      <a href={url} target="_blank" rel="noopener noreferrer" class="tool-cta">
        <span data-i18n="visit_tool">Visit Tool</span> <span class="cta-arrow">&nearr;</span>
      </a>
    </header>

    <!-- Section 3: Tagline -->
    <p class="tool-tagline">{tagline}</p>

    <!-- Section 4: Body Content -->
    <div class="tool-body">
      <Content />
    </div>

    <!-- Section 5: Verdicts -->
    {verdicts && verdicts.length > 0 && (
      <section class="tool-verdicts">
        <h2 class="verdicts-heading" data-i18n="what_users_say">What Users Say</h2>
        {verdicts.map((verdict) => (
          <blockquote class="verdict-card">
            <span class="verdict-quote-mark">&ldquo;</span>
            <p class="verdict-text">{verdict.quote}</p>
            <footer class="verdict-source">&mdash; {verdict.source}</footer>
          </blockquote>
        ))}
      </section>
    )}

    <!-- Section 6: Additional Screenshots -->
    {screenshots.length > 1 && (
      <div class={`tool-gallery ${screenshots.length === 2 ? 'single' : ''}`}>
        {screenshots.slice(1).map((img) => (
          <div class="gallery-item">
            <img src={img} alt={title} loading="lazy" />
          </div>
        ))}
      </div>
    )}

    <!-- Section 7: Footer Navigation -->
    <footer class="tool-footer">
      <a href="/tools" class="back-link" data-i18n="all_tools">&larr; All Tools</a>
      {nextTool && nextTool.slug !== tool.slug && (
        <a href={`/tools/${nextTool.slug}`} class="next-link">
          <span data-i18n="next_tool">Next: </span>{nextTool.data.title} &rarr;
        </a>
      )}
    </footer>
  </article>
</BaseLayout>

<style>
  .tool-detail {
    max-width: 800px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Hero Screenshot */
  .tool-hero {
    width: 100%;
    border-radius: var(--radius-card, 20px);
    overflow: hidden;
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .tool-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Header */
  .tool-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .tool-header-left {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
  }

  .tool-detail-logo {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    object-fit: cover;
    flex-shrink: 0;
  }

  .tool-header-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .tool-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text, #ebe5de);
    margin: 0;
    line-height: 1.15;
  }

  .tool-category-pill {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--tool-color);
    background: color-mix(in srgb, var(--tool-color) 12%, transparent);
    border-radius: var(--radius-pill, 100px);
    padding: 4px 12px;
    width: fit-content;
  }

  .tool-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-pill, 100px);
    border: 1px solid var(--color-text-muted, rgba(235,229,222,0.6));
    color: var(--color-text, #ebe5de);
    text-decoration: none;
    transition: opacity 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tool-cta:hover {
    opacity: 0.85;
  }

  .cta-arrow {
    font-size: 16px;
  }

  /* Tagline */
  .tool-tagline {
    font-family: var(--font-body);
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-text-muted, rgba(235,229,222,0.6));
    margin: 0;
    max-width: 660px;
  }

  /* Body */
  .tool-body {
    max-width: 660px;
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text, #ebe5de);
  }

  .tool-body :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .tool-body :global(h2:first-child) {
    margin-top: 0;
  }

  .tool-body :global(p) {
    margin: 0 0 1em;
  }

  .tool-body :global(ul),
  .tool-body :global(ol) {
    margin: 0 0 1em;
    padding-left: 0;
    list-style: none;
    border-left: 2px solid var(--tool-color, var(--color-accent, #e4432e));
    padding-left: 16px;
  }

  .tool-body :global(li) {
    margin-bottom: 0.5em;
    font-size: 15px;
  }

  .tool-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .tool-body :global(a) {
    color: var(--color-accent, #e4432e);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Verdicts */
  .tool-verdicts {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .verdicts-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .verdict-card {
    background: var(--color-bg-alt, #141218);
    border-radius: var(--radius-card, 20px);
    padding: 32px;
    border: none;
    border-left: 3px solid var(--tool-color, var(--color-accent));
    position: relative;
    margin: 0;
    opacity: 1;
    font-style: normal;
    font-size: 1rem;
  }

  .verdict-quote-mark {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 4rem;
    line-height: 1;
    color: var(--tool-color, var(--color-accent));
    opacity: 0.25;
    position: absolute;
    top: 16px;
    left: 24px;
  }

  .verdict-text {
    font-family: var(--font-serif, 'Noto Serif SC', serif);
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0 0 16px;
    color: var(--color-text, #ebe5de);
    padding-top: 12px;
  }

  .verdict-source {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-muted, rgba(235,229,222,0.5));
    font-weight: 500;
  }

  /* Gallery */
  .tool-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .tool-gallery.single {
    grid-template-columns: 1fr;
  }

  .gallery-item {
    border-radius: 12px;
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover {
    transform: scale(1.02);
  }

  .gallery-item img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  /* Footer Nav */
  .tool-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid var(--color-border, rgba(255,255,255,0.08));
  }

  .back-link,
  .next-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted, rgba(235,229,222,0.6));
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover,
  .next-link:hover {
    color: var(--color-text, #ebe5de);
  }

  .next-link {
    text-align: right;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .tool-detail {
      padding: 24px 16px 60px;
      gap: 28px;
    }

    .tool-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .tool-title {
      font-size: 1.75rem;
    }

    .tool-detail-logo {
      width: 52px;
      height: 52px;
      border-radius: 14px;
    }

    .tool-tagline {
      font-size: 1.05rem;
    }

    .tool-gallery {
      grid-template-columns: 1fr;
    }

    .verdict-card {
      padding: 24px;
    }

    .verdict-quote-mark {
      font-size: 3rem;
      left: 16px;
      top: 10px;
    }

    .tool-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .next-link {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .tool-title {
      font-size: 1.5rem;
    }

    .tool-cta {
      padding: 8px 16px;
      font-size: 13px;
    }

    .tool-body {
      font-size: 15px;
    }

    .verdict-text {
      font-size: 0.875rem;
    }
  }
</style>
